---
/**
 * Arctic Night chrome for Content Engine article pages (/uutiset/) on
 * Kasinot ilman rekisteröitymistä (kasinotilmanrekisteroitymista.com).
 *
 * The site's REAL header, slide menu, footer and affiliate-disclosure bar
 * are sliced out of the scraped homepage fragment at build time, so article
 * pages always match the rest of the site — including after a re-scrape
 * (`npm run sync:content`). ShortPixel lazy-load placeholders are decoded
 * to real image URLs at build time so no spai script is needed here.
 *
 * COMPLIANCE (do not remove):
 * - The sliced footer + .kir-affiliate-disclosure bar carry the mandatory
 *   affiliate disclosure and responsible-gambling notice (18+ / Peluuri.fi).
 *   The live site was penalised partly for a MISSING disclosure.
 * - Article HTML is rendered verbatim via <slot /> — affiliate links keep
 *   their rel="sponsored nofollow" attributes; never strip or rewrite them.
 * - Never add "I tested / first-hand experience" claims to any copy here.
 */
import homeBody from "../fragments/home/body.html?raw";
import homeHead from "../fragments/home/head.html?raw";

interface Props {
  title: string;
  description: string;
  canonicalPath: string; // e.g. /uutiset/artikkelin-slug/
  publishedAt?: string | null;
  heroImage?: string | null;
  /** "article" renders NewsArticle JSON-LD + og:type article; "index" is plain. */
  kind?: "article" | "index";
}
const {
  title,
  description,
  canonicalPath,
  publishedAt = null,
  heroImage = null,
  kind = "article",
} = Astro.props;

const siteName = "Kasinot ilman rekisteröitymistä";
const siteUrl = "https://kasinotilmanrekisteroitymista.com";
const canonical = new URL(canonicalPath, Astro.site ?? siteUrl).href;

const fmtDate = new Intl.DateTimeFormat("fi-FI", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const jsonLd =
  kind === "article"
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        headline: title,
        description,
        inLanguage: "fi",
        datePublished: publishedAt ?? undefined,
        image: heroImage ?? undefined,
        publisher: { "@type": "Organization", name: siteName, url: siteUrl },
      })
    : null;

/* ---- Site chrome, sliced from the scraped homepage fragment ---- */
function sliceBetween(src: string, startMarker: string, endMarker: string, includeEnd = false): string {
  const a = src.indexOf(startMarker);
  if (a === -1) throw new Error(`ArticleLayout: marker not found: ${startMarker}`);
  const b = src.indexOf(endMarker, a);
  if (b === -1) throw new Error(`ArticleLayout: marker not found: ${endMarker}`);
  return src.slice(a, includeEnd ? b + endMarker.length : b);
}

/* ShortPixel adaptive images use base64 SVG placeholders; the real image URL
   sits URL-encoded in a data-u attribute INSIDE the encoded SVG. Decode at
   build time → plain <img>, no spai script needed on article pages. */
function decodeSpai(html: string): string {
  return html.replace(
    /<img\b[^>]*src="data:image\/svg\+xml;base64,([^"]+)"[^>]*>/g,
    (tag, b64) => {
      const svg = Buffer.from(b64, "base64").toString("utf8");
      const dataU = svg.match(/data-u="([^"]+)"/)?.[1];
      if (!dataU) return tag;
      const real = decodeURIComponent(dataU).replace(siteUrl, "");
      return tag
        .replace(/src="data:[^"]*"/, `src="${real}"`)
        .replace(/\s+data-spai="[^"]*"/g, "");
    },
  );
}

// header + mobile slide menu (everything between the header tag and the hero)
const headerHtml = decodeSpai(
  sliceBetween(homeBody, '<header id="site-header"', '<section class="container-fluid kir-hero"'),
);
const footerHtml = decodeSpai(sliceBetween(homeBody, "<footer", "</footer>", true));
const disclosureHtml = sliceBetween(homeBody, '<div class="kir-affiliate-disclosure"', "</style>", true);

// the theme/bootstrap stylesheet stack the chrome depends on
const styleLinks = (homeHead.match(/<link[^>]*rel=['"]stylesheet['"][^>]*>/g) ?? []).join("\n");
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={kind === "article" ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fi_FI" />
    {heroImage && <meta property="og:image" content={heroImage} />}
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <script is:inline id="jquery-js" src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.4.1/jquery.min.js?ver=3.4.1"></script>
    <Fragment set:html={styleLinks} />
    {/* Arctic Night design system (shared with the migrated pages). */}
    <link rel="preload" href="/fonts/inter-var-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/redesign.css" />
    <script src="/vendor/lenis.min.js" defer></script>
    <script src="/vendor/gsap.min.js" defer></script>
    <script src="/vendor/ScrollTrigger.min.js" defer></script>
    <script src="/arctic.js" defer></script>
  </head>
  <body class="kir-article-page">
    <Fragment set:html={headerHtml} />

    <section class="container-fluid kir-hero">
      <div class="container px-0 px-lg-3">
        <h1 class="mb-0">{title}</h1>
        <span class="custom-breadcrumb mb-5">
          <a href="/">{siteName}</a>
          {" | "}
          <a href="/uutiset/">Uutiset</a>
          {kind === "article" && <> {" | "} <span>{title}</span></>}
        </span>
        {publishedAt && (
          <p class="article-meta mb-0 mt-3">
            <time datetime={publishedAt}>{fmtDate.format(new Date(publishedAt))}</time>
          </p>
        )}
      </div>
    </section>

    <main class="container article-shell">
      <article class="article-body">
        <slot />
      </article>
    </main>

    <Fragment set:html={footerHtml} />
    <Fragment set:html={disclosureHtml} />

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.15.0/umd/popper.min.js?ver=1.15.0"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.3.1/js/bootstrap.min.js?ver=4.3.1"></script>
    <script is:inline src="/wp-content/themes/affiliateKIR/theme/js/affiliateKIR.js?ver=1.0.0"></script>
  </body>
</html>

<style is:global>
  /* Article content, Arctic Night (tokens come from /redesign.css :root) */
  .article-meta {
    color: var(--ink-3);
    font-size: 0.9rem;
  }
  .article-shell {
    max-width: 860px;
    padding-bottom: 48px;
  }
  .article-body {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-1);
    padding: clamp(20px, 4vw, 44px);
    color: var(--ink-2);
    line-height: 1.75;
  }
  .article-body h2,
  .article-body h3 {
    color: var(--ink);
    margin-top: 2rem;
    margin-bottom: 0.8rem;
  }
  .article-body p {
    margin-bottom: 1.1rem;
  }
  .article-body img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }
  .article-body ul,
  .article-body ol {
    padding-left: 1.4rem;
    margin-bottom: 1.1rem;
  }
  .article-body table {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    margin: 1.25rem 0;
  }
  .article-body th,
  .article-body td {
    padding: 11px 14px;
    border-bottom: 1px solid var(--line);
    text-align: left;
  }
  .article-body th {
    background: var(--surface-2);
    color: var(--ink);
  }
  .article-body tr:last-child td {
    border-bottom: none;
  }
  .article-body blockquote {
    border-left: 3px solid var(--teal);
    background: var(--teal-soft);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 14px 18px;
  }
  @media (max-width: 767px) {
    .article-shell {
      padding-left: 14px;
      padding-right: 14px;
    }
  }
</style>
