---
/**
 * Minimal Finnish chrome for Content Engine article pages (/uutiset/) on
 * Kasinot ilman rekisteröitymistä (kasinotilmanrekisteroitymista.com).
 *
 * The real site's header/footer haven't been scraped into fragments yet, so
 * this is a clean, self-contained placeholder layout. Once the home fragments
 * exist, replace the marked header/footer blocks.
 *
 * COMPLIANCE (do not remove):
 * - Affiliate-disclosure line in the header area. The live site was penalised
 *   partly for a MISSING affiliate disclosure — it is mandatory on every page
 *   that contains affiliate links.
 * - Responsible-gambling notice (18+ / Peluuri.fi) in the footer.
 * - Article HTML is rendered verbatim via <slot /> — affiliate links keep
 *   their rel="sponsored nofollow" attributes; never strip or rewrite them.
 * - Never add "I tested / first-hand experience" claims to any copy here.
 */
interface Props {
  title: string;
  description: string;
  canonicalPath: string; // e.g. /uutiset/artikkelin-slug/
  publishedAt?: string | null;
  heroImage?: string | null;
  /** "article" renders NewsArticle JSON-LD + og:type article; "index" is plain. */
  kind?: "article" | "index";
}
const {
  title,
  description,
  canonicalPath,
  publishedAt = null,
  heroImage = null,
  kind = "article",
} = Astro.props;

const siteName = "Kasinot ilman rekisteröitymistä";
const siteUrl = "https://kasinotilmanrekisteroitymista.com";
const canonical = new URL(canonicalPath, Astro.site ?? siteUrl).href;

const fmtDate = new Intl.DateTimeFormat("fi-FI", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const jsonLd =
  kind === "article"
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        headline: title,
        description,
        inLanguage: "fi",
        datePublished: publishedAt ?? undefined,
        image: heroImage ?? undefined,
        publisher: { "@type": "Organization", name: siteName, url: siteUrl },
      })
    : null;
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={kind === "article" ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fi_FI" />
    {heroImage && <meta property="og:image" content={heroImage} />}
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    {/* Arctic Night design system (shared with the migrated pages). */}
    <link rel="preload" href="/fonts/inter-var-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/redesign.css" />
    <script src="/vendor/lenis.min.js" defer></script>
    <script src="/vendor/gsap.min.js" defer></script>
    <script src="/vendor/ScrollTrigger.min.js" defer></script>
    <script src="/arctic.js" defer></script>
    <style>
      :root {
        --bg: #ffffff;
        --text: #1c1c1c;
        --muted: #5a5f66;
        --border: #e3e6ea;
        --accent: #0b5fa5;
        --notice-bg: #f4f6f8;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--text); font: 16px/1.65 system-ui, -apple-system, "Segoe UI", sans-serif; }
      .container { max-width: 760px; margin: 0 auto; padding: 0 20px; }
      a { color: var(--accent); }
      .site-header { border-bottom: 1px solid var(--border); padding: 16px 0; }
      .site-header .container { display: flex; flex-wrap: wrap; align-items: center; gap: 12px 24px; }
      .site-name { font-weight: 700; font-size: 1.1rem; color: var(--text); text-decoration: none; }
      .site-nav a { margin-right: 16px; font-size: 0.95rem; text-decoration: none; }
      .site-nav a:hover { text-decoration: underline; }
      .disclosure { background: var(--notice-bg); border-bottom: 1px solid var(--border); font-size: 0.82rem; color: var(--muted); padding: 8px 0; }
      main { padding: 32px 0 48px; }
      .article-date { font-size: 0.85rem; color: var(--muted); margin: 0 0 20px; }
      .article-hero-img { width: 100%; max-height: 380px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 24px; }
      h1 { font-size: 1.9rem; line-height: 1.25; margin: 0 0 10px; }
      .prose :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 18px 0; }
      .prose :global(table) { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin: 0 0 16px; }
      .prose :global(th), .prose :global(td) { border: 1px solid var(--border); padding: 8px 12px; text-align: left; }
      .prose :global(th) { background: var(--notice-bg); }
      .rg-notice { background: var(--notice-bg); border-top: 1px solid var(--border); text-align: center; font-size: 0.9rem; padding: 16px 0; }
      .rg-notice strong { color: var(--text); }
      .site-footer { border-top: 1px solid var(--border); font-size: 0.82rem; color: var(--muted); padding: 20px 0 28px; }
    </style>
  </head>
  <body>
    <!-- TODO: replace with scraped site header/footer from src/fragments/home/body.html -->
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-name">{siteName}</a>
        <nav class="site-nav" aria-label="Päävalikko">
          <!-- Placeholder nav until the real header is ported -->
          <a href="/">Etusivu</a>
          <a href="/uutiset/">Uutiset</a>
        </nav>
      </div>
    </header>

    <!-- Affiliate disclosure — MANDATORY, the site was penalised partly for lacking it. -->
    <div class="disclosure">
      <div class="container">
        Mainossisältöä: tämä sivusto sisältää affiliate-linkkejä. Voimme saada
        komission, jos siirryt kasinolle linkkiemme kautta — tämä ei vaikuta
        arvioihimme eikä aiheuta sinulle kuluja.
      </div>
    </div>

    <main>
      <article class="container">
        <h1>{title}</h1>
        {publishedAt && (
          <p class="article-date">
            Julkaistu: <time datetime={publishedAt}>{fmtDate.format(new Date(publishedAt))}</time>
          </p>
        )}
        <div class="prose">
          {heroImage && <img class="article-hero-img" src={heroImage} alt={title} />}
          <slot />
        </div>
      </article>
    </main>

    <div class="rg-notice">
      <div class="container">
        <strong>Pelaa vastuullisesti. 18+</strong> — Jos pelaaminen huolestuttaa,
        apua saat maksutta: <a href="https://www.peluuri.fi/" rel="noopener">Peluuri.fi</a>
      </div>
    </div>

    <!-- TODO: replace with scraped site header/footer from src/fragments/home/body.html -->
    <footer class="site-footer">
      <div class="container">
        &copy; 2026 {siteName} — Vain täysi-ikäisille (18+). Sivusto sisältää
        affiliate-linkkejä.
      </div>
    </footer>
  </body>
</html>
