# Matching Visions Content Engine feed (articles published under /uutiset/).
#
# Where the values come from: the engine dashboard -> Keys. Create a
# SITE-SCOPED API key for "Kasinot ilman rekisteröitymistä" with the
# `articles:read` scope. CE_API_URL is the engine deployment's API base
# (including /v1). Set both locally in .env and in Vercel -> Settings ->
# Environment Variables.
#
# Both are optional: without them the build still succeeds, /uutiset/ is
# just empty of engine articles.
CE_API_URL=https://<engine-deployment>/v1
CE_API_KEY=<site-scoped key with articles:read>
